# Theseus Phase 0 — environment template
# Copy → .env on the VPS. Never commit a populated .env.

# ===== PostgreSQL =====
# Theseus runs on its own PG instance; port MUST differ from Win³.
THESEUS_PG_HOST=127.0.0.1
THESEUS_PG_PORT=5433
THESEUS_PG_DB=theseus
THESEUS_PG_USER=theseus
THESEUS_PG_PASSWORD=CHANGEME
THESEUS_PG_POOL_MAX=5

# Win³ PG port — set so isolation check can compare. Leave blank if not co-located.
WIN3_PG_PORT=5432

# ===== Kill switch =====
# File-based; default ~/Theseus_Phase0/control/.killed
THESEUS_KILL_FILE=

# ===== LLM (Batch 2) =====
ANTHROPIC_API_KEY=CHANGEME
THESEUS_LLM_MODEL=claude-opus-4-5-20251201

# ===== Cost monitoring (Batch 2 — gap #3) =====
# Confirmed by Akio 2026-05-09: $100/month cap (soft hourly $5, hard daily $20)
THESEUS_COST_MONTHLY_USD=100
THESEUS_COST_HARD_DAILY_USD=20
THESEUS_COST_SOFT_HOURLY_USD=5

# ===== Discord webhooks (Batch 3 — Akio creates manually) =====
# Placeholder URLs; replace with real webhooks on deploy.
DISCORD_WEBHOOK_BRIEFING=PLACEHOLDER_THESEUS_BRIEFING
DISCORD_WEBHOOK_ALERTS=PLACEHOLDER_THESEUS_ALERTS
DISCORD_WEBHOOK_B2B_LEADS=PLACEHOLDER_THESEUS_B2B_LEADS

# ===== Operational =====
THESEUS_LOG_LEVEL=INFO
THESEUS_TZ=America/New_York
